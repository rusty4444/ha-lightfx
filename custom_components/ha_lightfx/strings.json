          "zone": "Zone"
        }
      },
      "edit_light": {
        "title": "Edit Light",
        "description": "{hint}",
        "data": {
          "entity_id": "Light Entity",
          "x": "X Position (0-100)",
          "y": "Y Position (0-100)",
          "z": "Z Depth (0-100)",
          "zone": "Zone"
